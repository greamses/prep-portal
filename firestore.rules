rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ─────────────────────────────
       AUTH HELPERS
    ───────────────────────────── */
    function isLoggedIn() {
      return request.auth != null;
    }

    // Admin is identified by your specific email
    function isAdmin() {
      return isLoggedIn() && request.auth.token.email == 'eemadanyel@gmail.com';
    }

    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    function isValidEncryptedKey(key) {
      return key is map &&
        key.cipher is string &&
        key.iv is string &&
        key.cipher.size() > 20 &&
        key.iv.size() > 10;
    }

    // Money / entitlement fields a normal user must NEVER set on themselves.
    // These are written only by the server (Admin SDK, which bypasses rules) or
    // by an admin. Without this guard a user could self-grant isPremium / forge
    // the partner-earnings fields.
    function protectedUserFields() {
      return [
        'isPremium', 'planId', 'planName', 'planTier', 'billingCycle',
        'lastPaymentRef', 'subscriptionExpiry', 'role',
        'referredByCode', 'referredByPartner', 'referralCyclesPaid',
        'featureOverrides'
      ];
    }
    function notTouchingProtected() {
      return !request.resource.data.diff(resource.data)
                .affectedKeys().hasAny(protectedUserFields());
    }

    /* ─────────────────────────────
       USERS COLLECTION
    ───────────────────────────── */
    match /users/{userId} {
      allow read: if isLoggedIn() && (request.auth.uid == userId || isAdmin());

      // A user may create their own profile, but not as premium (no paying for
      // free) — admins can create anything.
      allow create: if isAdmin() ||
        (isOwner(userId) && request.resource.data.get('isPremium', false) == false);

      // Admin may update anything; an owner may update their own profile EXCEPT
      // the protected entitlement/money fields, and any BYUK keys must be valid.
      allow update: if
        (isAdmin() || (isOwner(userId) && notTouchingProtected())) &&
        (
          !('geminiKey' in request.resource.data) ||
          isValidEncryptedKey(request.resource.data.geminiKey)
        ) &&
        (
          !('groqKey' in request.resource.data) ||
          isValidEncryptedKey(request.resource.data.groqKey)
        ) &&
        (
          !('youtubeKey' in request.resource.data) ||
          isValidEncryptedKey(request.resource.data.youtubeKey)
        );

      allow delete: if isAdmin();
    }

    /* ─────────────────────────────
       AI FLASHCARDS (Recall Press) — a user's own decks, private.
    ───────────────────────────── */
    match /users/{userId}/flashcardDecks/{deckId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    /* ─────────────────────────────
       POSTS & BLOGS (DYNAMICS ENABLED)
    ───────────────────────────── */

    // Automatically matches any collection ending with "-posts" or named "blogs"
    function isPostCollection(col) {
      return col.matches('.*-posts') || col == 'blogs';
    }

    match /{postCollection}/{postId} {
      // Blog posts are PUBLIC: anyone (signed in or not) can read them.
      // Any other top-level collection caught by this generic rule keeps the
      // previous behaviour (signed-in read only).
      allow read: if isPostCollection(postCollection) || isLoggedIn();

      // View counts may be bumped by anyone (so anonymous reads still count);
      // likes require a signed-in user.
      allow update: if isPostCollection(postCollection) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) ||
        (isLoggedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likes']))
      );

      allow write: if isAdmin();

      // Nested Comments and Replies (Recursive wildcard matches sub-collections).
      // Anyone can READ comments; only signed-in users can add them; a user may
      // delete their OWN comment; the admin override at the bottom lets the admin
      // delete ANY comment.
      match /comments/{commentId=**} {
        allow read: if true;
        allow create: if isLoggedIn() && request.resource.data.authorId == request.auth.uid;
        allow update: if isLoggedIn() && (
          resource.data.authorId == request.auth.uid ||
          // anyone signed-in may like a comment, or bump its denormalised
          // replyCount when they post a reply to it (no per-comment read needed).
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount'])
        );
        allow delete: if isLoggedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    /* ─────────────────────────────
       DASHBOARD COLLECTIONS
    ───────────────────────────── */
    match /assignments/{assignmentId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin() || (isLoggedIn() && (
        request.resource.data.teacherId == request.auth.uid ||
        resource.data.teacherId == request.auth.uid
      ));
    }

    match /classes/{classId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Site config flags (e.g. archiveEnabled) — written only by an admin; read
    // by the server (Admin SDK). Client read is harmless.
    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Our own AI-generated CBT bank — admin-written, served via /api/cbt.
    match /cbtQuestions/{id} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Admin-set image overrides for any image slot (scientist portraits, and
    // any puzzle/drill/activity image). One doc per namespace, a map of
    // slotKey -> url. Public read so everyone sees the chosen image; admin-only
    // write. See utils/components/admin-images.js.
    match /imageOverrides/{namespace} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Cartesian Art puzzles — coordinate-plotting "trace the picture" missions.
    // Authored by the admin (client-side, allowed by the admin override too) and
    // played by any signed-in learner, so a shared link works.
    match /cartesianArt/{puzzleId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    /* ─────────────────────────────
       ACTIVITIES (teacher-authored question sets)
       Created/updated ONLY by the server (Admin SDK, which bypasses rules).
       The question set is readable by any signed-in user (so a shared link
       works), but is written server-side. Private student submissions live in
       a SUBcollection that NO client rule grants — that placement matters: the
       broad single-segment rule above (/{postCollection}/{postId}) only matches
       top-level docs, so a subcollection is never exposed by it. Only the server
       (Admin SDK) and admins (catch-all below) can read/write submissions.
    ───────────────────────────── */
    match /activities/{activityId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();

      match /submissions/{submissionId} {
        allow read, write: if false;
      }
    }

    /* ─────────────────────────────
       CLASSROOM (roster + assignments) — server-mediated (Admin SDK).
       Join codes are written server-side; the private bits — a teacher's
       student roster and each student's assigned activities — live in
       SUBcollections that no client rule grants, so only the server and admins
       can read them.
    ───────────────────────────── */
    match /classCodes/{code} {
      allow read: if isLoggedIn();   // a code→teacher lookup is not sensitive
      allow write: if isAdmin();
    }
    match /teacherClass/{teacherUid} {
      allow read: if isLoggedIn() && (request.auth.uid == teacherUid || isAdmin());
      allow write: if isAdmin();
    }
    match /teacherStudents/{teacherUid}/roster/{studentUid} {
      allow read, write: if false;   // server/admin only
    }
    match /studentAssignments/{studentUid}/items/{activityId} {
      allow read, write: if false;   // server/admin only
    }
    match /studentStats/{studentUid}/private/{doc} {
      allow read, write: if false;   // server/admin only (a student's aggregate scores)
    }

    /* ─────────────────────────────
       PARTNER EARNINGS (server-mediated only)
       partners / referralCodes / earnings / paymentEvents / payouts are written
       ONLY by the server (Admin SDK) and read via authenticated API endpoints,
       so the admin override below is the only client access they get. Listed
       here as documentation — no client rule needed.
    ───────────────────────────── */

    /* ─────────────────────────────
       DRILLS — timed multiplayer times-tables practice
       Rooms are ephemeral game sessions, not user data. Questions and bot
       scores are derived client-side from the room's `seed` (never stored),
       so these rules only need to cover matchmaking + each player's own
       final score, written exactly once at round end.
    ───────────────────────────── */
    match /drillRoomPointers/{bucketKey} {
      // Low-sensitivity, ephemeral matchmaking pointer (roomId + expiresAt
      // only) — worst case a bad write misdirects matchmaking for one
      // bucket, never touches scores or player data.
      allow read, write: if isLoggedIn();
    }

    match /drillRooms/{roomId} {
      allow read: if isLoggedIn();

      allow create: if isLoggedIn() &&
        request.resource.data.hostUid == request.auth.uid &&
        request.resource.data.status == 'waiting' &&
        request.resource.data.playerCount == 1 &&
        request.resource.data.size in [2, 5, 10] &&
        request.resource.data.timeLimit in [30, 60, 90, 120] &&
        request.resource.data.operations is list &&
        request.resource.data.operations.size() > 0 &&
        request.resource.data.operations.hasOnly([
          'add', 'multiply', 'divide',
          'square', 'sqrt', 'cube', 'cuberoot', 'power4', 'fourthroot',
          'fracAdd', 'fracSub', 'fracMul', 'fracDiv',
          'rmm'
        ]) &&
        request.resource.data.tables is list &&
        request.resource.data.tables.size() > 0 &&
        request.resource.data.tables.size() <= 100 &&
        request.resource.data.fractionTypes is list &&
        request.resource.data.fractionTypes.hasOnly(['like', 'unlike', 'wholeFraction']) &&
        // Chemistry (operation 'rmm'): which sets of the compound bank are in
        // play — empty for every other category. Optional ONLY because a tab
        // left open across this rule's deploy is running the JS from before
        // the field existed, and a hard `is list` would refuse that player a
        // room of ANY category. Present-but-wrong is still rejected.
        (!('compounds' in request.resource.data) || (
          request.resource.data.compounds is list &&
          request.resource.data.compounds.hasOnly(['inorganic', 'organic'])
        ));

      allow update: if isLoggedIn() && (
        // A join: playerCount +1, never past size, nothing else changes.
        (resource.data.status == 'waiting' &&
          request.resource.data.playerCount == resource.data.playerCount + 1 &&
          request.resource.data.playerCount <= resource.data.size &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerCount'])) ||
        // Activation: waiting -> active, forward only. Deliberately NOT
        // gated to hostUid — any remaining connected member may promote an
        // abandoned room (see matchmaking.js's abandon-fallback timer); the
        // status precondition already guarantees only one such write wins.
        (resource.data.status == 'waiting' &&
          request.resource.data.status == 'active' &&
          request.resource.data.botsNeeded == request.resource.data.size - resource.data.playerCount &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'startAt', 'botsNeeded']))
      );

      allow delete: if false; // rooms simply age out (unread docs aren't billed)

      match /players/{uid} {
        allow read: if isLoggedIn();
        allow create: if isOwner(uid) &&
          request.resource.data.keys().hasOnly(['displayName', 'joinedAt']);
        // Final score is written exactly once — the pre-state check blocks
        // rewriting a doc that's already been scored.
        allow update: if isOwner(uid) &&
          !('score' in resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score', 'finishedAt']);
      }
    }

    /* ─────────────────────────────
       VOCAB — timed multiplayer A-Z hangman
       Same shape as DRILLS above, but a room is described by subject+grade
       rather than operations+tables — its own collection so each game's
       validation can stay tight instead of loosening both. The words
       themselves are derived client-side from the room's `seed` against the
       static bank in /data/vocab, so nothing about them is ever stored.
    ───────────────────────────── */
    match /vocabRoomPointers/{bucketKey} {
      // Low-sensitivity, ephemeral matchmaking pointer (roomId + expiresAt
      // only) — worst case a bad write misdirects matchmaking for one
      // bucket, never touches scores or player data.
      allow read, write: if isLoggedIn();
    }

    match /vocabRooms/{roomId} {
      allow read: if isLoggedIn();

      allow create: if isLoggedIn() &&
        request.resource.data.hostUid == request.auth.uid &&
        request.resource.data.status == 'waiting' &&
        request.resource.data.playerCount == 1 &&
        request.resource.data.size in [2, 5, 10] &&
        // Derived from word count × pace (see main.js's computeTimeLimit), so
        // an arbitrary integer — a range is the honest check, same as Grammar.
        request.resource.data.timeLimit is int &&
        request.resource.data.timeLimit >= 45 &&
        request.resource.data.timeLimit <= 900 &&
        // Two tiers of subject, and grades now run to 12 (see data/vocab/topics.js).
        // The tiers are not cross-checked against the grade here: a mismatched
        // room would simply deal a player the wrong-but-valid word list, which
        // costs nobody anything — the rules exist to stop a client writing a
        // room shape the game can't read, not to re-implement the curriculum.
        request.resource.data.subject in [
          'life-science', 'earth-science', 'physical-science', 'space-science',
          'general-maths', 'biology', 'chemistry', 'physics', 'algebra',
          'geometry', 'statistics', 'geography'
        ] &&
        request.resource.data.grade is int &&
        request.resource.data.grade >= 1 &&
        request.resource.data.grade <= 12 &&
        request.resource.data.playMode in ['az', 'topic'] &&
        request.resource.data.spelling in ['classic', 'spell'] &&
        request.resource.data.topic is string &&
        request.resource.data.topic.size() <= 40;

      allow update: if isLoggedIn() && (
        // A join: playerCount +1, never past size, nothing else changes.
        (resource.data.status == 'waiting' &&
          request.resource.data.playerCount == resource.data.playerCount + 1 &&
          request.resource.data.playerCount <= resource.data.size &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerCount'])) ||
        // Activation: waiting -> active, forward only. Deliberately NOT gated
        // to hostUid — any remaining connected member may promote an abandoned
        // room (see matchmaking.js's abandon-fallback timer); the status
        // precondition already guarantees only one such write wins.
        (resource.data.status == 'waiting' &&
          request.resource.data.status == 'active' &&
          request.resource.data.botsNeeded == request.resource.data.size - resource.data.playerCount &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'startAt', 'botsNeeded']))
      );

      allow delete: if false; // rooms simply age out (unread docs aren't billed)

      match /players/{uid} {
        allow read: if isLoggedIn();
        allow create: if isOwner(uid) &&
          request.resource.data.keys().hasOnly(['displayName', 'joinedAt']);
        // Final score is written exactly once — the pre-state check blocks
        // rewriting a doc that's already been scored. Ranking is score, then
        // speed, then wrong guesses (see leaderboard.js's rankVocab), so
        // timeMs and wrong land in the one write alongside score.
        allow update: if isOwner(uid) &&
          !('score' in resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['score', 'finishedAt', 'timeMs', 'wrong']);
      }
    }

    /* ─────────────────────────────
       GRAMMAR — timed multiplayer passage editing (CUPS)
       Same shape as VOCAB above, but a room is described by grade + passage
       theme + which CUPS letters are being scored. The passage itself is
       derived client-side from the room's `seed` against the static bank in
       /data/grammar, so nothing about it — and none of the player's edits —
       is ever stored.

       NOTE the timeLimit rule: unlike the older games' fixed whitelists, this
       clock is DERIVED (passage length × reading pace + errors × pace, see the
       page's main.js), so it is an arbitrary integer. Validating it as a range
       is the honest form here — a whitelist would reject every legitimate room.
    ───────────────────────────── */
    match /grammarRoomPointers/{bucketKey} {
      // Low-sensitivity, ephemeral matchmaking pointer (roomId + expiresAt
      // only) — worst case a bad write misdirects matchmaking for one
      // bucket, never touches scores or player data.
      allow read, write: if isLoggedIn();
    }

    match /grammarRooms/{roomId} {
      allow read: if isLoggedIn();

      allow create: if isLoggedIn() &&
        request.resource.data.hostUid == request.auth.uid &&
        request.resource.data.status == 'waiting' &&
        request.resource.data.playerCount == 1 &&
        request.resource.data.size in [2, 5, 10] &&
        // Derived, so a range — see the note above. The client clamps to
        // [90, 900]; the wider bound here just stops absurd values.
        request.resource.data.timeLimit is int &&
        request.resource.data.timeLimit >= 60 &&
        request.resource.data.timeLimit <= 1800 &&
        request.resource.data.grade is int &&
        request.resource.data.grade >= 1 &&
        request.resource.data.grade <= 12 &&
        request.resource.data.theme in [
          'diary', 'story', 'letter', 'report', 'science',
          'wildlife', 'history', 'discovery'
        ] &&
        // The CUPS focus, canonicalised client-side to a subset of "cups"
        // (see data/grammar/cups.js's focusKey). Length-checked rather than
        // enumerated so adding a letter never needs a rules deploy.
        request.resource.data.focus is string &&
        request.resource.data.focus.size() >= 1 &&
        request.resource.data.focus.size() <= 4 &&
        // How many passages the round pages through. Bounded rather than
        // enumerated so raising the cap client-side never needs a rules
        // deploy; the real ceiling is timeLimit, which scales with it.
        request.resource.data.count is int &&
        request.resource.data.count >= 1 &&
        request.resource.data.count <= 5;

      allow update: if isLoggedIn() && (
        // A join: playerCount +1, never past size, nothing else changes.
        (resource.data.status == 'waiting' &&
          request.resource.data.playerCount == resource.data.playerCount + 1 &&
          request.resource.data.playerCount <= resource.data.size &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerCount'])) ||
        // Activation: waiting -> active, forward only. Deliberately NOT gated
        // to hostUid — any remaining connected member may promote an abandoned
        // room (see seeded-room.js's abandon-fallback timer); the status
        // precondition already guarantees only one such write wins.
        (resource.data.status == 'waiting' &&
          request.resource.data.status == 'active' &&
          request.resource.data.botsNeeded == request.resource.data.size - resource.data.playerCount &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'startAt', 'botsNeeded']))
      );

      allow delete: if false; // rooms simply age out (unread docs aren't billed)

      match /players/{uid} {
        allow read: if isLoggedIn();
        allow create: if isOwner(uid) &&
          request.resource.data.keys().hasOnly(['displayName', 'joinedAt']);
        // Final result is written exactly once — the pre-state check blocks
        // rewriting a doc that's already been scored. This game ranks on more
        // than score (speed, then false edits) and shows a caught/named split
        // on the results card, so all six fields land in the one write.
        allow update: if isOwner(uid) &&
          !('score' in resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['score', 'finishedAt', 'timeMs', 'falseEdits', 'caught', 'tagged']);
      }
    }

    /* ─────────────────────────────
       PUZZLES — timed multiplayer puzzle racing (Sudoku for now)
       Same shape as DRILLS above — rooms are ephemeral game sessions, and
       the puzzle itself (givens + solution) is derived client-side from
       the room's `seed` (never stored), so these rules only need to cover
       matchmaking + each player's own final score, written exactly once
       at round end.
    ───────────────────────────── */
    match /puzzleRoomPointers/{bucketKey} {
      // Low-sensitivity, ephemeral matchmaking pointer (roomId + expiresAt
      // only) — worst case a bad write misdirects matchmaking for one
      // bucket, never touches scores or player data.
      allow read, write: if isLoggedIn();
    }

    match /puzzleRooms/{roomId} {
      allow read: if isLoggedIn();

      allow create: if isLoggedIn() &&
        request.resource.data.hostUid == request.auth.uid &&
        request.resource.data.status == 'waiting' &&
        request.resource.data.playerCount == 1 &&
        request.resource.data.size in [2, 5, 10] &&
        request.resource.data.timeLimit in [180, 300, 600, 900] &&
        request.resource.data.puzzleType in ['sudoku', 'slider', 'jigsaw', 'shikaku'] &&
        request.resource.data.difficulty in ['easy', 'medium', 'hard'] &&
        // Each puzzle divides differently: Sudoku's boxes only work at 4/6/9,
        // Slider is the classic 3/4/5, Jigsaw is table-sized at 10/15/20
        // (100–400 pieces), and Shikaku cuts rectangles out of 5/7/10. See
        // main.js's GRID_SIZES_BY_TYPE.
        request.resource.data.gridSize in [3, 4, 5, 6, 7, 9, 10, 15, 20] &&
        // What the room is playing WITH: Slider's tile set (numbers /
        // fractions / picture), or what the Jigsaw is a jigsaw OF (a photo,
        // or the Map of Nigeria with its state outlines shown or hidden).
        // Sudoku and Shikaku always send 'numbers'. Deliberately not tied to
        // puzzleType — a mismatch is harmless (each puzzle reads the field
        // only if it means something to it) and cross-checking it here would
        // mean updating two places for every new tile set.
        //
        // Optional only because it postdates the collection: a room doc
        // written by JS from before `tiles` existed carries none, and
        // game.js already reads a missing one as 'numbers'. Present-but-junk
        // is still refused.
        (!('tiles' in request.resource.data) ||
          request.resource.data.tiles in ['numbers', 'fractions', 'picture', 'photo', 'nigeria', 'nigeria-blank']);

      allow update: if isLoggedIn() && (
        // A join: playerCount +1, never past size, nothing else changes.
        (resource.data.status == 'waiting' &&
          request.resource.data.playerCount == resource.data.playerCount + 1 &&
          request.resource.data.playerCount <= resource.data.size &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerCount'])) ||
        // Activation: waiting -> active, forward only. Deliberately NOT
        // gated to hostUid — any remaining connected member may promote an
        // abandoned room (see matchmaking.js's abandon-fallback timer); the
        // status precondition already guarantees only one such write wins.
        (resource.data.status == 'waiting' &&
          request.resource.data.status == 'active' &&
          request.resource.data.botsNeeded == request.resource.data.size - resource.data.playerCount &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'startAt', 'botsNeeded']))
      );

      allow delete: if false; // rooms simply age out (unread docs aren't billed)

      match /players/{uid} {
        allow read: if isLoggedIn();
        allow create: if isOwner(uid) &&
          request.resource.data.keys().hasOnly(['displayName', 'joinedAt']);
        // Final score is written exactly once — the pre-state check blocks
        // rewriting a doc that's already been scored.
        allow update: if isOwner(uid) &&
          !('score' in resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score', 'finishedAt']);
      }
    }

    /* ─────────────────────────────
       GEOMETRY — timed multiplayer perimeter/circumference racing
       Same shape as DRILLS/PUZZLES above — rooms are ephemeral game
       sessions, and each question is derived client-side from the room's
       `seed` (never stored), so these rules only need to cover matchmaking
       + each player's own final score, written exactly once at round end.
    ───────────────────────────── */
    match /geometryRoomPointers/{bucketKey} {
      // Low-sensitivity, ephemeral matchmaking pointer (roomId + expiresAt
      // only) — worst case a bad write misdirects matchmaking for one
      // bucket, never touches scores or player data.
      allow read, write: if isLoggedIn();
    }

    match /geometryRooms/{roomId} {
      allow read: if isLoggedIn();

      allow create: if isLoggedIn() &&
        request.resource.data.hostUid == request.auth.uid &&
        request.resource.data.status == 'waiting' &&
        request.resource.data.playerCount == 1 &&
        request.resource.data.size in [2, 5, 10] &&
        request.resource.data.timeLimit in [30, 60, 90, 120] &&
        request.resource.data.shapes is list &&
        request.resource.data.shapes.size() > 0 &&
        request.resource.data.shapes.hasOnly([
          'circle', 'semicircle', 'quadrant', 'sector', 'triangle', 'rectangle', 'square'
        ]) &&
        request.resource.data.given is list &&
        request.resource.data.given.hasOnly(['radius', 'diameter']) &&
        request.resource.data.lengths is list &&
        request.resource.data.lengths.size() > 0 &&
        request.resource.data.lengths.size() <= 20;

      allow update: if isLoggedIn() && (
        // A join: playerCount +1, never past size, nothing else changes.
        (resource.data.status == 'waiting' &&
          request.resource.data.playerCount == resource.data.playerCount + 1 &&
          request.resource.data.playerCount <= resource.data.size &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerCount'])) ||
        // Activation: waiting -> active, forward only. Deliberately NOT
        // gated to hostUid — any remaining connected member may promote an
        // abandoned room (see matchmaking.js's abandon-fallback timer); the
        // status precondition already guarantees only one such write wins.
        (resource.data.status == 'waiting' &&
          request.resource.data.status == 'active' &&
          request.resource.data.botsNeeded == request.resource.data.size - resource.data.playerCount &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'startAt', 'botsNeeded']))
      );

      allow delete: if false; // rooms simply age out (unread docs aren't billed)

      match /players/{uid} {
        allow read: if isLoggedIn();
        allow create: if isOwner(uid) &&
          request.resource.data.keys().hasOnly(['displayName', 'joinedAt']);
        // Final score is written exactly once — the pre-state check blocks
        // rewriting a doc that's already been scored.
        allow update: if isOwner(uid) &&
          !('score' in resource.data) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score', 'finishedAt']);
      }
    }

    /* ─────────────────────────────
       ADMIN OVERRIDE
    ───────────────────────────── */
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
