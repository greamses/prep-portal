rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Prep Portal — Firestore security rules  (Phase 1 of partner earnings)
//
// ⚠️  REVIEW BEFORE DEPLOYING. Firestore deploys the WHOLE file at once and this
//     replaces whatever rules are currently live in your Firebase console. Open
//     Firebase Console → Firestore → Rules, compare with what's below, and run
//     each case in the Rules Playground before publishing.
//
// The point of this file: premium status and all money records can NO LONGER be
// written by the browser — only by the server (Admin SDK bypasses rules) or by
// an admin (the `admin:true` custom claim, set on sign-in for ADMIN_EMAIL).
// `assignments` / `classes` / `alocQuestions` are left at authenticated-access
// because their ownership model isn't encoded here yet — tighten them later.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isAdmin()  { return request.auth != null && request.auth.token.admin == true; }
    function isOwner(uid) { return request.auth != null && request.auth.uid == uid; }

    // Fields a normal user must never set or change on their own profile —
    // these are written only by the server (payments) or an admin.
    function protectedUserFields() {
      return [
        'isPremium', 'planId', 'planName', 'planTier', 'billingCycle',
        'lastPaymentRef', 'subscriptionExpiry', 'role',
        'balanceKobo', 'lifetimeKobo', 'referredByCode', 'referredByPartner',
        'referralCyclesPaid'
      ];
    }
    function touchesProtected() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(protectedUserFields());
    }

    // ── User profiles ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      // A new profile may only be created as a non-premium student by its owner.
      allow create: if isAdmin() ||
        (isOwner(uid)
          && request.resource.data.get('isPremium', false) == false
          && request.resource.data.get('role', 'student') == 'student');
      // Owners may edit non-protected fields (name, etc.); premium/plan/role and
      // the earnings fields are admin/server only.
      allow update: if isAdmin() || (isOwner(uid) && !touchesProtected());
      allow delete: if isAdmin();
    }

    // ── Money / partner-earnings (server + admin only) ─────────────
    match /paymentEvents/{ref}  { allow read, write: if isAdmin(); }
    match /partners/{id}        { allow read: if isAdmin() || isOwner(id);
                                  allow write: if isAdmin(); }
    match /referralCodes/{code} { allow read: if signedIn();   // validate a code
                                  allow write: if isAdmin(); }
    match /earnings/{id}        { allow read, write: if isAdmin(); }
    match /payouts/{id}         { allow read, write: if isAdmin(); }

    // ── AI / curation ──────────────────────────────────────────────
    match /aiUsage/{uid}           { allow read: if isOwner(uid) || isAdmin();
                                     allow write: if isAdmin(); }   // server writes
    match /byukKeys/{uid}          { allow read, write: if false; } // server only (raw keys)
    match /solutionSteps/{doc}     { allow read: if signedIn(); allow write: if isAdmin(); }
    match /solverExpressions/{doc} { allow read: if signedIn(); allow write: if isAdmin(); }
    match /config/{doc}            { allow read: if signedIn(); allow write: if isAdmin(); }

    // ── Not-yet-modelled app data (kept working; tighten later) ─────
    match /alocQuestions/{doc} { allow read: if signedIn(); allow write: if isAdmin(); }
    match /assignments/{doc}   { allow read, write: if signedIn(); }
    match /classes/{doc}       { allow read, write: if signedIn(); }

    // Everything else: deny by default.
    match /{document=**} { allow read, write: if false; }
  }
}
