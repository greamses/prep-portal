# Copy to `.env` (gitignored) and fill in. Used by `npm run deploy` / `npm run purge`
# to purge Cloudflare's edge cache after a production deploy.
#
# Token needs the "Zone → Cache Purge → Purge" permission for prepportal.com.ng.
# Create one at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Optional — defaults to the prepportal.com.ng zone if omitted.
# CLOUDFLARE_ZONE_ID=
