# ─── Prep Portal Backend — Environment Variables ───────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env or serviceAccountKey.json to git.

# ── Server ──────────────────────────────────────────────────────
PORT=5000
# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: http://localhost:3000,https://prepportal.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# ── Firebase Admin ───────────────────────────────────────────────
# Option A (local dev): put serviceAccountKey.json next to this file
#   Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
#
# Option B (production): paste the JSON as a single-line string here
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Admin Access ──────────────────────────────────────────────────
ADMIN_EMAIL=your-admin@email.com

# ── Anthropic Claude ─────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Default Claude model used for PrepBot fallback and direct /api/ai/claude calls
# Options: claude-haiku-4-5-20251001 (fast/cheap) | claude-sonnet-4-6 (balanced) | claude-opus-4-7 (best)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Paystack ─────────────────────────────────────────────────────
# Secret key — server-side only for webhook verification
# Get from: Paystack Dashboard → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_live_...
