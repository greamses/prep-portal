{
  "name": "prep-portal-server",
  "version": "2.0.0",
  "description": "Prep Portal API backend — secures AI keys and payment processing",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "edit:cbt": "cross-env CBT_STATIC_STORE=1 nodemon index.js",
    "cbt:sync": "node scripts/sync-cbt-firestore.js",
    "cbt:sync:dry": "node scripts/sync-cbt-firestore.js --dry",
    "cbt:sync:seed": "node scripts/sync-cbt-firestore.js --seed",
    "import:aloc": "node scripts/import-aloc.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@google-cloud/text-to-speech": "^6.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
